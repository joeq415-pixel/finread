ANTHROPIC_API_KEY=your_anthropic_api_key_here
JWT_SECRET=change_this_to_a_long_random_string
PORT=3000

# Stripe (TEST mode) — from Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Dashboard > Product catalog > create a "FinRead Pro" recurring price > copy its Price ID
STRIPE_PRICE_ID_PRO=price_your_pro_price_id_here
# From `stripe listen --forward-to localhost:3000/api/billing/webhook` (Stripe CLI)
# or Dashboard > Developers > Webhooks > signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
